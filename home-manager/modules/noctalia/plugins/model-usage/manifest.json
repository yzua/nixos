{
	"id": "model-usage",
	"name": "Model Usage",
	"version": "0.2.1",
	"minNoctaliaVersion": "3.6.0",
	"author": "cmptr",
	"license": "MIT",
	"description": "Shows AI coding assistant usage stats in the bar with detail panel (Claude Code, Codex, Copilot, OpenRouter, Zen, Z.ai)",
	"repository": "https://github.com/noctalia-dev/noctalia-plugins",
	"tags": ["Bar", "Productivity", "AI"],
	"entryPoints": {
		"main": "Main.qml",
		"barWidget": "BarWidget.qml",
		"panel": "Panel.qml",
		"settings": "Settings.qml"
	},
	"dependencies": {
		"plugins": []
	},
	"metadata": {
		"defaultSettings": {
			"providers": {
				"claude": {
					"enabled": true,
					"statsPath": "~/.claude/stats-cache.json",
					"credentialsPath": "~/.claude/.credentials.json"
				},
				"codex": {
					"enabled": true
				},
				"copilot": {
					"enabled": false
				},
				"openrouter": {
					"enabled": false,
					"apiKey": ""
				},
				"zen": {
					"enabled": false,
					"apiKey": ""
				},
				"zai": {
					"enabled": true
				}
			},
			"barDisplayMode": "active",
			"barCycleIntervalSec": 5,
			"barMetric": "prompts",
			"refreshIntervalSec": 30
		}
	}
}
