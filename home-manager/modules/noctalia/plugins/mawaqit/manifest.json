{
  "id": "mawaqit",
  "name": "Mawaqit",
  "version": "1.3.5",
  "minNoctaliaVersion": "4.1.0",
  "author": "User",
  "license": "MIT",
  "repository": "https://github.com/noctalia-dev/noctalia-plugins",
  "description": "Shows prayer times with a live countdown and a Hijri calendar with Islamic events.",
  "tags": [
    "Bar",
    "Panel"
  ],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "city": "London",
      "country": "UK",
      "method": 3,
      "school": 0,
      "showCountdown": true,
      "showElapsed": false,
      "hidePrayerName": false,
      "showNotifications": true,
      "playAzan": false,
      "azanFile": "azan1.mp3",
      "hijriDayOffset": 0,
      "tune": false,
      "tuneFajr": 0,
      "tuneDhuhr": 0,
      "tuneAsr": 0,
      "tuneMaghrib": 0,
      "tuneIsha": 0,
      "widgetIcon": "building-mosque",
      "dynamicIcon": false,
      "textColor": "none",
      "iconColor": "none",
      "activeColor": "primary"
    }
  }
}
